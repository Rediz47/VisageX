# Server-side Gemini / Vertex key. Required for AI analysis endpoints.
VERTEX_API_KEY=
VERTEX_USE_OAUTH=

APP_URL=https://visagex.online

VITE_SITE_PASSWORD=

# Paddle Configuration
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENV=sandbox
VITE_PADDLE_PRICE_SINGLE=
VITE_PADDLE_PRICE_BASIC=
VITE_PADDLE_PRICE_PRO=
PADDLE_WEBHOOK_SECRET=

# Resend Configuration
# Get this from your Resend Dashboard (https://resend.com)
RESEND_API_KEY=

# Upstash Redis (rate limiting, caching, webhook replay protection)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin Configuration
ADMIN_EMAILS=

# Cloudflare Turnstile (CAPTCHA)
# Get these from https://dash.cloudflare.com → Turnstile
# VITE_ prefix = exposed to frontend (site key is public)
VITE_TURNSTILE_SITE_KEY=
# Secret key stays server-side only — NEVER prefix with VITE_
TURNSTILE_SECRET_KEY=

# Fraud Detection Thresholds (optional, sensible defaults applied)
FRAUD_MAX_ACCOUNTS_PER_IP=3
FRAUD_MAX_REFERRALS_PER_HOUR=5
FRAUD_SCAN_SPIKE_THRESHOLD=20

# Firebase
FIREBASE_SERVICE_ACCOUNT=
FIRESTORE_DATABASE_ID=

# PostHog
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# GCP (optional overrides)
GCP_PROJECT=
GCP_REGION=us-central1
GEMINI_MODEL=gemini-2.5-flash
