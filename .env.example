# VERTEX_API_KEY: Required for Vertex AI API calls.
# Get this from your Google Cloud Console > Vertex AI > API Keys.
# Users configure this via the Secrets panel in the AI Studio UI.
VERTEX_API_KEY="MY_VERTEX_API_KEY"
# WARNING: Do NOT add VITE_VERTEX_API_KEY — any VITE_ prefixed var is bundled into the client JS and publicly exposed.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SITE_PASSWORD: Set this to a password to make the entire website private.
# If left empty, the website will be public.
VITE_SITE_PASSWORD=

# PayPal Configuration
# Get these from your PayPal Developer Dashboard (https://developer.paypal.com)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
VITE_PAYPAL_CLIENT_ID=

# Resend Configuration
# Get this from your Resend Dashboard (https://resend.com)
RESEND_API_KEY=

# Upstash Redis (rate limiting, caching, webhook replay protection)
# Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PayPal Webhook ID (required in production for signature verification)
PAYPAL_WEBHOOK_ID=

# Admin Configuration
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@example.com

# Cloudflare Turnstile (CAPTCHA)
# Get these from https://dash.cloudflare.com → Turnstile
# VITE_ prefix = exposed to frontend (site key is public)
VITE_TURNSTILE_SITE_KEY=
# Secret key stays server-side only — NEVER prefix with VITE_
TURNSTILE_SECRET_KEY=

# Fraud Detection Thresholds (optional, sensible defaults applied)
FRAUD_MAX_ACCOUNTS_PER_IP=3
FRAUD_MAX_REFERRALS_PER_HOUR=5
FRAUD_SCAN_SPIKE_THRESHOLD=20

# Firebase
FIREBASE_SERVICE_ACCOUNT=
FIRESTORE_DATABASE_ID=

# GCP (optional overrides)
GCP_PROJECT=
GCP_REGION=us-central1
GEMINI_MODEL=gemini-2.5-flash
